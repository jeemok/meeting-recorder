# Copy to .env and fill in. Loaded automatically by the CLI.

# --- LLM provider (Claude / Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model used for summarization & suggestions.
# Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
# MEETING_RECORDER_MODEL=claude-opus-4-7

# Optional: where meetings are stored. Defaults to ./meetings
# MEETING_RECORDER_DIR=/Users/you/Documents/meetings

# Optional: Hugging Face token for pyannote diarization models.
# Required only if you opt into diarization. Get one at https://huggingface.co
# and accept the license at https://huggingface.co/pyannote/speaker-diarization-3.1
# HF_TOKEN=hf_...
