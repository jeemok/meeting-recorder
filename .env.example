# Optional environment overrides for the Meeting Recorder app.
#
# The app also reads these from
# ~/Library/Application Support/MeetingRecorder/.env when present.

# --- LLM provider (Claude / Anthropic) ---
# Used for post-call summaries and live question suggestions.
# You can also set this in-app under Settings → LLM.
ANTHROPIC_API_KEY=sk-ant-...

# --- Speaker diarization (optional) ---
# Required only if you opt into diarization in Settings → Transcription.
# Get a token at https://huggingface.co and accept the license at
# https://huggingface.co/pyannote/speaker-diarization-3.1
# HUGGING_FACE_HUB_TOKEN=hf_...
